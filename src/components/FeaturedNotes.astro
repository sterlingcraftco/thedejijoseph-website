---
import Icon from './Icon.astro';
import { getPosts } from '@/lib/ghost';
import { format } from 'date-fns';

// Latest three posts, fetched at build time.
const { posts } = await getPosts(1, 3, { tag: 'website' });
---

<section class="section-padding section-spacing relative overflow-hidden">
  <div class="absolute top-20 right-20 w-24 h-24 border-4 border-primary/10"></div>

  <div class="max-w-7xl mx-auto relative">
    <div class="mb-16 md:mb-20">
      <div class="accent-bar mb-6"></div>
      <h2 class="heading-section">
        Notes I've <span class="text-primary">written</span>
      </h2>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 md:gap-10">
      {posts.map((post) => (
        <a
          href={`/notes/${post.slug}`}
          class="bg-background border border-border/50 hover:border-primary/30 transition-all duration-500 card-hover group block"
        >
          {post.feature_image && (
            <div class="aspect-[16/9] overflow-hidden">
              <img
                src={post.feature_image}
                alt={post.feature_image_alt || post.title}
                class="w-full h-full object-cover grayscale group-hover:grayscale-0 transition-all duration-700"
                loading="lazy"
              />
            </div>
          )}
          <div class="p-8 space-y-4">
            <div class="flex items-center gap-4 text-xs text-muted-foreground">
              <time datetime={post.published_at}>
                {format(new Date(post.published_at), 'MMM d, yyyy')}
              </time>
              {post.reading_time > 0 && (
                <span class="flex items-center gap-1">
                  <Icon name="clock" class="w-3 h-3" />
                  {post.reading_time} min read
                </span>
              )}
            </div>

            <h3 class="font-display text-xl font-bold group-hover:text-primary transition-colors">
              {post.title}
            </h3>

            <p class="body-regular text-muted-foreground line-clamp-3">
              {post.custom_excerpt || post.excerpt}
            </p>

            <span class="inline-flex items-center gap-2 text-sm font-medium text-primary">
              Read more
              <Icon name="arrow-right" class="w-4 h-4 group-hover:translate-x-1 transition-transform" />
            </span>
          </div>
        </a>
      ))}
    </div>

    <a
      href="/notes"
      class="inline-flex items-center gap-2 text-primary font-medium hover:underline mt-12"
    >
      Read all notes
      <Icon name="arrow-right" class="w-4 h-4" />
    </a>
  </div>
</section>

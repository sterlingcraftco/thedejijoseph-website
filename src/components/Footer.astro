---
const socialLinks = [
  { name: 'X', url: 'https://x.com/thedejijoseph' },
  { name: 'Instagram', url: 'https://instagram.com/thedejijoseph' },
  { name: 'LinkedIn', url: 'https://www.linkedin.com/in/thedejijoseph' },
];

const navLinks = [
  { name: 'Home', path: '/' },
  { name: 'About', path: '/about' },
  { name: "Deji's Notes", path: '/notes' },
];
---

<footer class="section-padding section-spacing border-t border-border relative overflow-hidden">
  <!-- Geometric accent -->
  <div class="absolute bottom-0 right-0 w-40 h-40 border-4 border-primary/10 translate-x-1/2 translate-y-1/2"></div>

  <div class="max-w-7xl mx-auto relative z-10">
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-16 lg:gap-12">
      <!-- Brand Column -->
      <div class="space-y-6">
        <a href="/" class="flex items-center gap-3">
          <img src="/assets/logo.png" alt="Deji Joseph" class="h-10 w-auto" />
        </a>
        <p class="body-regular text-muted-foreground max-w-xs">
          LLMOps Engineer building AI infrastructure that delivers real business value.
        </p>
      </div>

      <!-- Navigation -->
      <div class="space-y-6">
        <h4 class="font-display font-bold text-sm uppercase tracking-wider text-muted-foreground">
          Navigation
        </h4>
        <nav class="flex flex-col gap-4">
          {navLinks.map((link) => (
            <a href={link.path} class="nav-link w-fit">{link.name}</a>
          ))}
        </nav>
      </div>

      <!-- Social -->
      <div class="space-y-6">
        <h4 class="font-display font-bold text-sm uppercase tracking-wider text-muted-foreground">
          Connect
        </h4>
        <div class="flex flex-col gap-4">
          {socialLinks.map((link) => (
            <a
              href={link.url}
              target="_blank"
              rel="noopener noreferrer"
              class="nav-link w-fit inline-flex items-center gap-2"
            >
              {link.name}
              <span class="text-primary">↗</span>
            </a>
          ))}
        </div>
      </div>
    </div>

    <!-- Copyright -->
    <div class="mt-20 pt-8 border-t border-border flex flex-col md:flex-row justify-between items-start md:items-center gap-4">
      <p class="text-sm text-muted-foreground">
        © 2026 The Deji Joseph. All rights reserved.
      </p>
      <div class="accent-bar"></div>
    </div>
  </div>
</footer>

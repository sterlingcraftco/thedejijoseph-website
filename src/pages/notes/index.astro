---
import Layout from '@/layouts/Layout.astro';
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
import Icon from '@/components/Icon.astro';
import NewsletterCta from '@/components/NewsletterCta.astro';
import { getPosts } from '@/lib/ghost';
import { format } from 'date-fns';

// Build-time fetch: every post + tag is rendered into static HTML so crawlers
// (and users without JS) get the full, linked list. Search and tag filtering
// are progressive enhancements over this server-rendered list.
const { posts } = await getPosts(1, 1000, { tag: 'website' });
const tags = Array.from(
  posts.reduce((acc, post) => {
    post.tags?.forEach((tag) => {
      if (tag.slug !== 'website' && !tag.name.startsWith('#')) {
        const existing = acc.get(tag.slug);
        if (existing && existing.count) {
          existing.count.posts++;
        } else {
          acc.set(tag.slug, { ...tag, count: { posts: 1 } });
        }
      }
    });
    return acc;
  }, new Map<string, import('@/lib/ghost').GhostTag>()).values()
).sort((a, b) => (b.count?.posts ?? 0) - (a.count?.posts ?? 0));
---

<Layout
  title="Notes"
  description="Thoughts as I learn them — on engineering, the things I'm building, and wherever curiosity leads."
  url="/notes"
>
  <Header />

  <main class="pt-24">
    <!-- Hero -->
    <section class="section-padding py-20 md:py-32 relative overflow-hidden">
      <div class="absolute top-20 right-10 w-32 h-32 border-4 border-primary/20"></div>
      <div class="absolute bottom-10 left-20 w-16 h-16 bg-primary/10"></div>

      <div class="max-w-7xl mx-auto relative z-10">
        <div class="max-w-3xl">
          <div class="accent-bar mb-6"></div>
          <h1 class="heading-hero mb-8">
            Notes I've <span class="text-primary">written</span>
          </h1>
          <p class="body-large text-muted-foreground mb-10">
            Thoughts as I learn them — on engineering, the things I'm building, and
            wherever curiosity leads.
          </p>

          <!-- Search -->
          <div class="flex items-stretch gap-3 max-w-lg">
            <div class="relative flex-1">
              <span class="absolute left-4 top-1/2 -translate-y-1/2 text-muted-foreground">
                <Icon name="search" class="w-4 h-4" />
              </span>
              <input
                id="notes-search"
                type="text"
                placeholder="Search notes..."
                class="w-full h-full pl-11 pr-10 py-3 bg-background border border-border text-foreground placeholder:text-muted-foreground focus:outline-none focus:border-primary transition-colors font-body text-sm"
              />
              <button
                id="notes-search-clear"
                type="button"
                class="hidden absolute right-3 top-1/2 -translate-y-1/2 text-muted-foreground hover:text-foreground transition-colors"
                aria-label="Clear search"
              >
                <Icon name="x" class="w-4 h-4" />
              </button>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Tags + Posts -->
    <section class="section-padding section-spacing bg-muted/30 relative overflow-hidden">
      <div class="absolute top-0 left-0 w-40 h-40 border-4 border-primary/10 -translate-x-1/2 -translate-y-1/2"></div>

      <div class="max-w-7xl mx-auto">
        {tags && tags.length > 0 && (
          <div class="mb-12">
            <div id="tag-filters" class="flex flex-wrap gap-3">
              <button
                data-tag="all"
                class="tag-btn px-4 py-2 text-xs font-medium uppercase tracking-wider border transition-all duration-300 bg-primary text-primary-foreground border-primary"
              >
                All
              </button>
              {tags.map((tag) => (
                <button
                  data-tag={tag.slug}
                  class="tag-btn px-4 py-2 text-xs font-medium uppercase tracking-wider border transition-all duration-300 bg-background text-muted-foreground border-border hover:border-primary/50"
                >
                  {tag.name}
                  {tag.count && <span class="ml-2 opacity-60">{tag.count.posts}</span>}
                </button>
              ))}
            </div>
          </div>
        )}

        <div id="notes-grid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 md:gap-10">
          {posts.map((post) => (
            <a
              href={`/notes/${post.slug}`}
              class="note-card bg-background border border-border/50 hover:border-primary/30 transition-all duration-500 card-hover group block"
              data-search={`${post.title} ${post.custom_excerpt || post.excerpt || ''}`.toLowerCase()}
              data-tags={(post.tags || []).map((t) => t.slug).join(' ')}
            >
              {post.feature_image && (
                <div class="aspect-[16/9] overflow-hidden">
                  <img
                    src={post.feature_image}
                    alt={post.feature_image_alt || post.title}
                    class="w-full h-full object-cover grayscale group-hover:grayscale-0 transition-all duration-700"
                    loading="lazy"
                  />
                </div>
              )}
              <div class="p-8 space-y-4">
                <div class="flex items-center gap-4 text-xs text-muted-foreground">
                  <time datetime={post.published_at}>
                    {format(new Date(post.published_at), 'MMM d, yyyy')}
                  </time>
                  {post.reading_time > 0 && (
                    <span class="flex items-center gap-1">
                      <Icon name="clock" class="w-3 h-3" />
                      {post.reading_time} min read
                    </span>
                  )}
                </div>

                {post.primary_tag && (
                  <span class="inline-block px-3 py-1 text-xs font-medium bg-muted text-muted-foreground">
                    {post.primary_tag.name}
                  </span>
                )}

                <h2 class="font-display text-xl font-bold group-hover:text-primary transition-colors">
                  {post.title}
                </h2>

                <p class="body-regular text-muted-foreground line-clamp-3">
                  {post.custom_excerpt || post.excerpt}
                </p>

                <span class="inline-flex items-center gap-2 text-sm font-medium text-primary">
                  Read more
                  <Icon name="arrow-right" class="w-4 h-4 group-hover:translate-x-1 transition-transform" />
                </span>
              </div>
            </a>
          ))}
        </div>

        <div id="notes-empty" class="hidden text-center py-20">
          <p class="body-large text-muted-foreground mb-4">No posts found.</p>
          <button id="notes-clear-filters" class="text-primary hover:underline text-sm font-medium">
            Clear filters
          </button>
        </div>
      </div>
    </section>

    <NewsletterCta />
  </main>

  <Footer />
</Layout>

<script>
  // Progressive enhancement: filter the server-rendered cards in place.
  const search = document.getElementById('notes-search') as HTMLInputElement | null;
  const clearBtn = document.getElementById('notes-search-clear');
  const clearFilters = document.getElementById('notes-clear-filters');
  const empty = document.getElementById('notes-empty');
  const cards = Array.from(document.querySelectorAll<HTMLElement>('.note-card'));
  const tagButtons = Array.from(document.querySelectorAll<HTMLElement>('.tag-btn'));

  let activeTag = 'all';
  let query = '';

  const ACTIVE = ['bg-primary', 'text-primary-foreground', 'border-primary'];
  const INACTIVE = ['bg-background', 'text-muted-foreground', 'border-border', 'hover:border-primary/50'];

  function paintTags() {
    for (const btn of tagButtons) {
      const on = btn.dataset.tag === activeTag;
      btn.classList.remove(...(on ? INACTIVE : ACTIVE));
      btn.classList.add(...(on ? ACTIVE : INACTIVE));
    }
  }

  function apply() {
    let visible = 0;
    for (const card of cards) {
      const matchesTag = activeTag === 'all' || (card.dataset.tags || '').split(' ').includes(activeTag);
      const matchesQuery = !query || (card.dataset.search || '').includes(query);
      const show = matchesTag && matchesQuery;
      card.classList.toggle('hidden', !show);
      if (show) visible++;
    }
    empty?.classList.toggle('hidden', visible !== 0);
    clearBtn?.classList.toggle('hidden', query.length === 0);
  }

  search?.addEventListener('input', () => {
    query = search.value.trim().toLowerCase();
    apply();
  });

  clearBtn?.addEventListener('click', () => {
    if (search) search.value = '';
    query = '';
    apply();
  });

  clearFilters?.addEventListener('click', () => {
    activeTag = 'all';
    query = '';
    if (search) search.value = '';
    paintTags();
    apply();
  });

  for (const btn of tagButtons) {
    btn.addEventListener('click', () => {
      activeTag = btn.dataset.tag || 'all';
      paintTags();
      apply();
    });
  }
</script>

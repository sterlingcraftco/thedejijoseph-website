# ---------------------------------------------------------------------------
# Runtime configuration.
#
# This is the full set of variables the app needs. They are RUNTIME env vars
# for the Hono backend (server/), supplied to the container as environment
# variables (Dokploy "Environment", or `docker run -e ...`).
#
# Nothing is required at Docker BUILD time: the Astro frontend hardcodes the
# Ghost Content API URL + public key in src/lib/ghost.ts, so `astro build`
# (the build-frontend stage) takes no build args.
# ---------------------------------------------------------------------------

# Ghost Admin API key — format: {id}:{secret}
# Used by server/routes/ghost.ts to create members (newsletter subscribe).
GHOST_ADMIN_API_KEY="your_ghost_admin_api_key_here"

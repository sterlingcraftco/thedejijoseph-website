---
import Layout from '@/layouts/Layout.astro';
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
---

<Layout
  title="About"
  description="I'm Deji. Engineer, builder, occasional product thinker. My career hasn't followed a lane — it's followed curiosity."
  url="/about"
>
  <Header />
  <main class="pt-32 md:pt-40">
    <section class="section-padding section-spacing relative overflow-hidden">
      <div class="absolute top-40 right-10 w-32 h-32 border-4 border-primary/20"></div>
      <div class="absolute bottom-20 left-10 w-20 h-20 bg-primary/10"></div>

      <div class="max-w-7xl mx-auto relative">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 lg:gap-20 items-center">
          <!-- Image on left (grayscale -> color on hover) -->
          <div class="relative">
            <div class="aspect-[4/5] overflow-hidden relative group">
              <img
                src="/assets/about-headshot-new.jpg"
                alt="Deji Joseph"
                class="w-full h-full object-cover grayscale transition-all duration-700 group-hover:grayscale-0 group-hover:scale-105"
              />
              <div class="absolute top-6 left-6 w-full h-full border-4 border-primary -z-10"></div>
            </div>
          </div>

          <!-- Text on right -->
          <div class="space-y-6 lg:pl-8">
            <div class="accent-bar"></div>

            <h1 class="heading-section">
              About <span class="text-primary">me</span>
            </h1>

            <p class="body-large">
              I'm <span class="font-bold text-primary">Deji</span>. Engineer,
              builder, occasional product thinker.
            </p>

            <p class="body-regular text-muted-foreground">
              My career hasn't followed a lane — it's followed curiosity. I started
              coordinating container logistics operations, built the tools to track
              them, then moved into product and technical roles in fintech,
              healthcare, and crypto. I've led teams and worked alone. I've written
              infrastructure and written product specs. I've been the person who
              builds the thing and the person who figures out what the thing should
              be.
            </p>

            <p class="body-regular text-muted-foreground">
              Right now I'm going deep on data and AI — not because I've found my
              final destination, but because it's where the most interesting
              problems are at this moment. Before this it was crypto payments
              infrastructure. Before that, operations systems. There will be a next
              thing.
            </p>

            <p class="body-regular text-muted-foreground">
              What stays constant: I show up, I go deep, and I build things that
              work.
            </p>
          </div>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>

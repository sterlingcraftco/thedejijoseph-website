---
import Layout from '@/layouts/Layout.astro';
import Header from '@/components/Header.astro';
import Hero from '@/components/Hero.astro';
import Introduction from '@/components/Introduction.astro';
import SelectedBuilds from '@/components/SelectedBuilds.astro';
import CuriosityNow from '@/components/CuriosityNow.astro';
import Footer from '@/components/Footer.astro';
---

<Layout
  title="Engineer"
  description="I've built payments infrastructure on a blockchain, managed deployments for a social platform, designed data systems for a healthcare agency, and parsed SMS alerts to automate savings. The industries change. The instinct doesn't."
  url="/"
>
  <Header />
  <main>
    <Hero />
    <Introduction />
    <SelectedBuilds />
    <CuriosityNow />
  </main>
  <Footer />
</Layout>

---
import Icon from './Icon.astro';
---

<section class="section-padding section-spacing bg-secondary text-secondary-foreground relative overflow-hidden">
  <!-- Geometric accents -->
  <div class="absolute top-10 left-10 w-20 h-20 border-2 border-primary/30"></div>
  <div class="absolute bottom-10 right-10 w-12 h-12 bg-primary/20"></div>

  <div class="max-w-7xl mx-auto relative">
    <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-10">
      <div class="space-y-6">
        <div class="w-16 h-1 bg-primary"></div>
        <h2 class="heading-section">
          wanna work
          <br />
          <span class="text-primary">with me?</span>
        </h2>
      </div>

      <a
        href="mailto:hello@thedejijoseph.com?subject=Partnership"
        class="btn-primary bg-primary text-primary-foreground hover:bg-primary/90"
      >
        <Icon name="mail" class="w-4 h-4" />
        Get in touch
        <Icon name="arrow-right" class="w-4 h-4" />
      </a>
    </div>
  </div>
</section>

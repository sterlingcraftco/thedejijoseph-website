---
import Icon from './Icon.astro';
import SubscribeForm from './SubscribeForm.tsx';
---

<section class="section-padding section-spacing relative overflow-hidden">
  <div class="absolute top-10 right-10 w-24 h-24 border-4 border-primary/10"></div>

  <div class="max-w-3xl mx-auto text-center">
    <div class="accent-bar mx-auto mb-8"></div>
    <span class="inline-flex text-primary mb-6"><Icon name="mail" class="w-10 h-10" /></span>
    <h2 class="heading-section mb-4">
      Stay <span class="text-primary">Updated</span>
    </h2>
    <p class="body-large text-muted-foreground mb-10">
      Subscribe to get new posts delivered straight to your inbox.
    </p>
    <SubscribeForm client:visible />
  </div>
</section>

---
---

<section class="section-padding py-24 md:py-32 relative overflow-hidden">
  <!-- Background accent -->
  <div class="absolute top-0 right-0 w-1/3 h-full bg-primary/5"></div>

  <div class="max-w-7xl mx-auto relative z-10">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-center">
      <!-- Text on left -->
      <div class="space-y-6">
        <div class="accent-bar"></div>
        <h2 class="heading-section">
          Hi, I'm <span class="text-primary">Deji</span>
        </h2>
        <p class="body-large text-muted-foreground">
          An ML Pipeline Architect and AI Infrastructure Specialist building
          the automated factories that train, deploy, and monitor machine
          learning models at scale.
        </p>
        <p class="body-regular text-muted-foreground">
          I specialize in LLMOps—managing GPU clusters, automating model
          retraining pipelines, and building robust infrastructure for
          Large Language Models that power modern AI applications.
        </p>
        <a
          href="/about"
          class="inline-flex items-center gap-2 text-primary font-medium hover:underline"
        >
          Learn more about me
          <span aria-hidden="true">→</span>
        </a>
      </div>

      <!-- Image on right -->
      <div class="relative">
        <div class="aspect-[4/5] overflow-hidden relative group">
          <img
            src="/assets/about-headshot.avif"
            alt="Deji Joseph"
            class="w-full h-full object-cover grayscale transition-all duration-700 group-hover:grayscale-0 group-hover:scale-105"
          />
          <div class="absolute top-6 left-6 w-full h-full border-4 border-primary -z-10"></div>
        </div>
      </div>
    </div>
  </div>
</section>

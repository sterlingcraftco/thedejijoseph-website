---
import { builds } from '@/data/builds';

const featured = builds.slice(0, 3);
---

<section class="section-padding section-spacing bg-muted/30 relative overflow-hidden">
  <div class="absolute top-0 left-0 w-40 h-40 border-4 border-primary/10 -translate-x-1/2 -translate-y-1/2"></div>

  <div class="max-w-7xl mx-auto relative">
    <div class="mb-16 md:mb-20">
      <div class="accent-bar mb-6"></div>
      <h2 class="heading-section">
        Stuff I've <span class="text-primary">built</span>
      </h2>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 md:gap-10">
      {featured.map((build) => (
        <div class="bg-background p-8 card-hover group border border-border/50 hover:border-primary/30 transition-all duration-500 space-y-5">
          <div class="w-8 h-1 bg-primary group-hover:w-12 transition-all duration-300"></div>
          <div class="space-y-2">
            <h3 class="font-display text-xl font-bold group-hover:text-primary transition-colors">
              {build.title}
            </h3>
            <p class="text-sm text-primary font-medium">{build.subtitle}</p>
          </div>
          <p class="body-regular text-muted-foreground">{build.description}</p>
        </div>
      ))}
    </div>

    <a
      href="/builds"
      class="inline-flex items-center gap-2 text-primary font-medium hover:underline mt-12"
    >
      See all builds
      <span aria-hidden="true">→</span>
    </a>
  </div>
</section>

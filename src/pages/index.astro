---
import Layout from '@/layouts/Layout.astro';
import Header from '@/components/Header.astro';
import Hero from '@/components/Hero.astro';
import Introduction from '@/components/Introduction.astro';
import CuriosityNow from '@/components/CuriosityNow.astro';
import ThingsIveBuilt from '@/components/ThingsIveBuilt.astro';
import FeaturedNotes from '@/components/FeaturedNotes.astro';
import NewsletterCta from '@/components/NewsletterCta.astro';
import Footer from '@/components/Footer.astro';
---

<Layout
  title="Engineer"
  description="Payments rails. Core banking. Blockchain rewards. Healthcare data. I've built the infrastructure layer across industries — and led the teams that made it reliable."
  url="/"
>
  <Header />
  <main>
    <Hero />
    <Introduction />
    <CuriosityNow />
    <ThingsIveBuilt />
    <FeaturedNotes />
    <NewsletterCta />
  </main>
  <Footer />
